@{
    ViewData["Title"] = "Đăng nhập - Phòng khám Delta";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0 rounded-3">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <h3 class="text-primary fw-bold">ĐĂNG NHẬP</h3>
                    <p class="text-muted small">Hệ thống Y tế Delta</p>
                </div>

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        @* ĐỔI name="phone" THÀNH name="phoneNumber" ĐỂ KHỚP CONTROLLER *@
                        <input type="text" name="phoneNumber" class="form-control" placeholder="Nhập số điện thoại đăng ký..." required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu</label>
                        <input type="password" name="password" class="form-control" placeholder="******" required />
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2 small border-0">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
                        </div>
                    }

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm">VÀO HỆ THỐNG</button>
                </form>

                <div class="text-center mt-4">
                    <p class="small text-muted">Chưa có hồ sơ tại Delta? <a asp-controller="Booking" asp-action="Register" class="text-decoration-none fw-bold">Đăng ký ngay</a></p>
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none small text-secondary"><i class="bi bi-arrow-left"></i> Quay lại trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</div>