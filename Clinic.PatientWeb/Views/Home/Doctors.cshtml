@model IEnumerable<Clinic.Shared.Model.Doctor>

@{
    ViewData["Title"] = "Đội ngũ Bác sĩ - Phòng khám Delta";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary text-uppercase">Đội ngũ Chuyên gia Delta</h2>
        <p class="text-muted">Hội tụ những bác sĩ tận tâm, giàu kinh nghiệm từ các bệnh viện hàng đầu.</p>
        <hr class="mx-auto" style="width: 80px; height: 4px; background-color: #0d6efd; border: none; border-radius: 2px;">
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var bs in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 doctor-card">
                        <img src="https://img.freepik.com/free-photo/doctor-offering-medical-teleconsultation_23-2149329007.jpg"
                             class="card-img-top object-fit-cover" style="height: 250px;" alt="Bác sĩ Delta">

                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold text-dark mb-2">
                                BS. @(bs.User?.FullName ?? "Đang cập nhật")
                            </h5>

                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill mb-3 px-3">
                                @(bs.Specialty?.SpecialtyName ?? "Đa khoa")
                            </span>

                            <div class="mb-3">
                                <p class="text-muted small mb-1">
                                    <i class="bi bi-briefcase me-1"></i> Kinh nghiệm: <strong>@bs.ExperienceYears năm</strong>
                                </p>
                                <p class="small text-secondary italic">
                                    @(string.IsNullOrEmpty(bs.Bio) ? "Chuyên gia y tế tận tâm tại hệ thống Delta." : bs.Bio)
                                </p>
                            </div>

                            <div class="d-grid mt-auto">
                                <a asp-controller="Booking" asp-action="CreateBooking"
                                   asp-route-doctorId="@bs.DoctorID"
                                   class="btn btn-primary fw-bold shadow-sm py-2">
                                    <i class="bi bi-calendar-check me-2"></i>ĐẶT LỊCH NGAY
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="alert alert-light border shadow-sm">
                    <i class="bi bi-people text-muted fs-1"></i>
                    <p class="mt-3 mb-0">Hiện tại danh sách bác sĩ đang được cập nhật. Vui lòng quay lại sau!</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Hiệu ứng phóng to nhẹ khi di chuột vào thẻ bác sĩ */
    .doctor-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .doctor-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(13, 110, 253, 0.15) !important;
        }

    .italic {
        font-style: italic;
    }
</style>