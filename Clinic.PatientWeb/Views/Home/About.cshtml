    @{
        ViewData["Title"] = "Giới thiệu phòng khám";
    }

    <div class="container mt-4">
        <div class="row align-items-center mb-5">
            <div class="col-md-6">
                <h1 class="display-5 fw-bold text-primary mb-3">Về Clinic System</h1>
                <p class="lead text-muted">Được thành lập từ năm 2010, Clinic System tự hào là đơn vị tiên phong trong việc ứng dụng công nghệ hiện đại vào quản lý y tế tại Việt Nam.</p>
                <p>Chúng tôi không chỉ cung cấp các dịch vụ khám chữa bệnh chất lượng cao mà còn mang đến trải nghiệm đặt lịch nhanh chóng, hồ sơ bảo mật tuyệt đối cho mọi khách hàng.</p>
            </div>
            <div class="col-md-6 text-center">
                <img src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&q=80&w=600"
                     class="img-fluid rounded-3 shadow" alt="Phòng khám">
            </div>
        </div>

        <div class="row text-center bg-primary text-white py-5 rounded-4 mb-5 shadow">
            <div class="col-md-3">
                <h2 class="fw-bold">15+</h2>
                <p>Năm kinh nghiệm</p>
            </div>
            <div class="col-md-3">
                <h2 class="fw-bold">50+</h2>
                <p>Bác sĩ chuyên khoa</p>
            </div>
            <div class="col-md-3">
                <h2 class="fw-bold">100k+</h2>
                <p>Bệnh nhân tin tưởng</p>
            </div>
            <div class="col-md-3">
                <h2 class="fw-bold">24/7</h2>
                <p>Hỗ trợ trực tuyến</p>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-md-6">
                <div class="p-4 border-start border-4 border-primary bg-light">
                    <h3 class="fw-bold"><i class="bi bi-eye"></i> Tầm nhìn</h3>
                    <p>Trở thành hệ thống y tế thông minh hàng đầu, nơi mọi người dân đều có thể tiếp cận dịch vụ y tế chất lượng chỉ bằng một cú click chuột.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-4 border-start border-4 border-success bg-light h-100">
                    <h3 class="fw-bold"><i class="bi bi-heart-pulse"></i> Sứ mệnh</h3>
                    <p>Tận tâm chăm sóc sức khỏe cộng đồng bằng sự tử tế, chuyên nghiệp và ứng dụng công nghệ vượt trội.</p>
                </div>
            </div>
        </div>
    </div>