@model IEnumerable<Clinic.Shared.Model.Facility>

<div class="container mt-5">
    <div class="text-center mb-5">
        <h6 class="text-primary fw-bold text-uppercase">Hệ thống Delta</h6>
        <h2 class="display-6 fw-bold">TRANG THIẾT BỊ HIỆN ĐẠI</h2>
        <p class="text-muted mx-auto" style="max-width: 600px;">
            Phòng khám Delta đầu tư đồng bộ các trang thiết bị y tế thế hệ mới nhất,
            giúp bác sĩ chẩn đoán chính xác và điều trị hiệu quả.
        </p>
        <div class="mt-3 mx-auto" style="width: 50px; height: 3px; background-color: #0d6efd;"></div>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden facility-card">
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/500x300?text=Delta+Medical" : item.ImageUrl)"
                                 class="card-img-top" alt="@item.FacilityName" style="height: 220px; object-fit: cover;">

                            @if (item.IsOperating)
                            {
                                <span class="position-absolute top-0 end-0 m-3 badge bg-success shadow-sm">
                                    <i class="bi bi-check-circle-fill me-1"></i> Hoạt động tốt
                                </span>
                            }
                        </div>

                        <div class="card-body p-4">
                            <h5 class="fw-bold text-dark mb-2">@item.FacilityName</h5>
                            <p class="text-muted small mb-0" style="text-align: justify;">
                                @item.Description
                            </p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="alert alert-warning d-inline-block px-5 shadow-sm border-0 rounded-pill">
                    <i class="bi bi-info-circle-fill me-2"></i> Đang tải dữ liệu thiết bị...
                </div>
            </div>
        }
    </div>
</div>

<style>
    .facility-card {
        transition: all 0.3s ease;
    }

        .facility-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .card-img-top {
        transition: transform 0.5s ease;
    }

    .facility-card:hover .card-img-top {
        transform: scale(1.05);
    }
</style>