@{
    ViewData["Title"] = "Trang chủ - Phòng khám Delta";
    var isLoggedIn = (bool)(ViewBag.IsLoggedIn ?? false);
    var fullName = ViewBag.FullName as string ?? "";
    var userPhone = ViewBag.UserPhone as string ?? "";
}

@if (isLoggedIn)
{
    <style>
        .quick-card {
            border-radius: 14px;
            border: none;
            box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            transition: transform .2s, box-shadow .2s;
            cursor: pointer;
            text-decoration: none;
            display: block;
        }

            .quick-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 24px rgba(0,0,0,0.12);
            }

        .stat-card {
            border-radius: 14px;
            border: none;
            box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        }

        .section-title {
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1px;
            color: #aaa;
            text-transform: uppercase;
            margin-bottom: 14px;
        }

        .welcome-card {
            background: linear-gradient(135deg, #0d6efd 0%, #0056d2 100%);
            border-radius: 20px;
            border: none;
            color: white;
        }

        .info-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 0;
            border-bottom: 1px solid #f0f0f0;
            font-size: 14px;
        }

            .info-row:last-child {
                border-bottom: none;
            }

        .badge-pulse {
            animation: pulse-red 1.5s infinite;
        }

        @@keyframes pulse-red {
            0% {
                box-shadow: 0 0 0 0 rgba(220,53,69,0.6);
            }

            70% {
                box-shadow: 0 0 0 7px rgba(220,53,69,0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(220,53,69,0);
            }
        }
    </style>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert"
             style="border-radius:12px;border:none;box-shadow:0 2px 12px rgba(25,135,84,0.15);">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        @* ===== CỘT TRÁI ===== *@
        <div class="col-lg-8">

            @* Welcome card *@
            <div class="card welcome-card p-4 mb-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:60px;height:60px;border-radius:50%;background:rgba(255,255,255,0.2);
                                        display:flex;align-items:center;justify-content:center;
                                        font-size:26px;font-weight:700;flex-shrink:0;">
                            @fullName[0].ToString().ToUpper()
                        </div>
                        <div>
                            <p class="mb-1 opacity-75" style="font-size:13px;">Xin chào trở lại 👋</p>
                            <h4 class="mb-1 fw-bold">@fullName</h4>
                            <p class="mb-0 opacity-75" style="font-size:13px;">
                                <i class="bi bi-telephone me-1"></i>@userPhone
                            </p>
                        </div>
                    </div>
                    <div class="text-end d-none d-md-block">
                        <p class="mb-1 opacity-75" style="font-size:12px;">Hôm nay</p>
                        <p class="mb-0 fw-semibold" style="font-size:15px;">@DateTime.Now.ToString("dd/MM/yyyy")</p>
                        <p class="mb-0 opacity-75" style="font-size:12px;">
                            @DateTime.Now.ToString("dddd", new System.Globalization.CultureInfo("vi-VN"))
                        </p>
                    </div>
                </div>
            </div>

            @* Thao tác nhanh *@
            <p class="section-title">Thao tác nhanh</p>
            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <a asp-controller="Booking" asp-action="CreateBooking" class="quick-card card text-center p-3">
                        <div style="width:48px;height:48px;border-radius:12px;background:#e8f0fe;
                                        display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
                            <i class="bi bi-calendar-plus text-primary" style="font-size:22px;"></i>
                        </div>
                        <div style="font-size:13px;font-weight:600;color:#333;">Đặt lịch khám</div>
                        <div style="font-size:11px;color:#aaa;margin-top:3px;">Nhanh chóng</div>
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-controller="Booking" asp-action="MyHistory" class="quick-card card text-center p-3">
                        <div style="width:48px;height:48px;border-radius:12px;background:#e6f9f0;
                                        display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
                            <i class="bi bi-clock-history text-success" style="font-size:22px;"></i>
                        </div>
                        <div style="font-size:13px;font-weight:600;color:#333;">Lịch sử khám</div>
                        <div style="font-size:11px;color:#aaa;margin-top:3px;">Xem tất cả</div>
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-controller="Account" asp-action="Profile" class="quick-card card text-center p-3">
                        <div style="width:48px;height:48px;border-radius:12px;background:#fff3e0;
                                        display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
                            <i class="bi bi-person-circle" style="font-size:22px;color:#fd7e14;"></i>
                        </div>
                        <div style="font-size:13px;font-weight:600;color:#333;">Hồ sơ</div>
                        <div style="font-size:11px;color:#aaa;margin-top:3px;">Cập nhật</div>
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-controller="Booking" asp-action="TrackProgress"
                       class="quick-card card text-center p-3 position-relative">
                        <span class="badge-pulse position-absolute"
                              style="top:10px;right:10px;width:10px;height:10px;
                                         border-radius:50%;background:#dc3545;display:block;"></span>
                        <div style="width:48px;height:48px;border-radius:12px;background:#ede7f6;
                                        display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
                            <i class="bi bi-activity" style="font-size:22px;color:#6f42c1;"></i>
                        </div>
                        <div style="font-size:13px;font-weight:600;color:#333;">Tiến trình khám</div>
                        <div style="font-size:11px;color:#dc3545;margin-top:3px;font-weight:500;">● Có cập nhật mới</div>
                    </a>
                </div>
            </div>

            @* Lịch hẹn sắp tới *@
            <p class="section-title">Lịch hẹn sắp tới</p>
            <div class="card stat-card mb-4">
                <div class="card-body p-4">
                    <div id="appt-loading" class="text-center py-2">
                        <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                        <span class="text-muted" style="font-size:13px;">Đang tải lịch hẹn...</span>
                    </div>
                    <div id="appt-found" style="display:none;">
                        <div class="d-flex align-items-center gap-3">
                            <div style="width:52px;height:52px;border-radius:14px;background:#e8f0fe;
                                            display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="bi bi-calendar2-check text-primary" style="font-size:24px;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div id="appt-date" style="font-size:15px;font-weight:700;color:#333;"></div>
                                <div id="appt-doctor" style="font-size:13px;color:#666;" class="mt-1"></div>
                                <div id="appt-status" class="mt-1"></div>
                            </div>
                            <a id="appt-track-link" href="#"
                               class="btn btn-sm btn-primary px-3"
                               style="border-radius:10px;white-space:nowrap;">
                                <i class="bi bi-activity me-1"></i> Theo dõi
                            </a>
                        </div>
                    </div>
                    <div id="appt-empty" style="display:none;" class="text-center py-3">
                        <div style="width:64px;height:64px;border-radius:50%;background:#f0f4ff;
                                        display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                            <i class="bi bi-calendar-x" style="font-size:28px;color:#c0c8e8;"></i>
                        </div>
                        <p class="text-muted mb-3" style="font-size:14px;">Bạn chưa có lịch hẹn nào sắp tới</p>
                        <a asp-controller="Booking" asp-action="CreateBooking"
                           class="btn btn-primary px-4" style="border-radius:10px;">
                            <i class="bi bi-plus-lg me-1"></i> Đặt lịch ngay
                        </a>
                    </div>
                </div>
            </div>

            @* Dịch vụ nổi bật *@
            <p class="section-title">Dịch vụ nổi bật</p>
            <div class="row g-3">
                @foreach (var service in new[] {
                        new { icon="bi-heart-pulse", color="#e8f0fe", icolor="#0d6efd",
                        name="Nội tổng quát", desc="Khám và điều trị các bệnh lý nội khoa" },
                        new { icon="bi-emoji-smile", color="#fce4ec", icolor="#e91e63",
                        name="Răng Hàm Mặt", desc="Điều trị nha khoa chuyên sâu" },
                        new { icon="bi-person-hearts", color="#e6f9f0", icolor="#198754",
                        name="Nhi khoa", desc="Chăm sóc sức khỏe trẻ em toàn diện" }
                        })
                {
                    <div class="col-md-4">
                        <div class="card stat-card p-3 h-100">
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:44px;height:44px;border-radius:10px;
                                                    background:@service.color;display:flex;
                                                    align-items:center;justify-content:center;flex-shrink:0;">
                                    <i class="bi @service.icon" style="font-size:20px;color:@service.icolor;"></i>
                                </div>
                                <div>
                                    <div style="font-size:14px;font-weight:600;">@service.name</div>
                                    <div style="font-size:12px;color:#aaa;">@service.desc</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ===== CỘT PHẢI ===== *@
        <div class="col-lg-4">
            <p class="section-title">Thông tin phòng khám</p>
            <div class="card stat-card mb-4">
                <div class="card-body p-3">
                    <div class="info-row">
                        <div style="width:36px;height:36px;border-radius:8px;background:#e8f0fe;
                                        display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-telephone-fill text-primary" style="font-size:15px;"></i>
                        </div>
                        <div>
                            <div style="font-size:12px;color:#aaa;">Hotline miễn phí</div>
                            <div style="font-size:15px;font-weight:700;color:#0d6efd;">1800 - 1234</div>
                        </div>
                    </div>
                    <div class="info-row">
                        <div style="width:36px;height:36px;border-radius:8px;background:#fce4ec;
                                        display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-geo-alt-fill" style="font-size:15px;color:#e91e63;"></i>
                        </div>
                        <div>
                            <div style="font-size:12px;color:#aaa;">Địa chỉ</div>
                            <div style="font-size:13px;font-weight:500;">123 Đường Lê Lợi, Q.1, TP.HCM</div>
                        </div>
                    </div>
                    <div class="info-row">
                        <div style="width:36px;height:36px;border-radius:8px;background:#e6f9f0;
                                        display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-clock-fill text-success" style="font-size:15px;"></i>
                        </div>
                        <div>
                            <div style="font-size:12px;color:#aaa;">Giờ làm việc</div>
                            <div style="font-size:13px;font-weight:500;">T2-T6: 7:00 - 20:00</div>
                            <div style="font-size:12px;color:#aaa;">T7-CN: 7:00 - 17:00</div>
                        </div>
                    </div>
                </div>
            </div>

            <p class="section-title">Lời khuyên hôm nay</p>
            <div class="card stat-card" style="background:linear-gradient(135deg,#f0f9ff,#e0f2fe);">
                <div class="card-body p-3">
                    @{
                        var tips = new[] {
                                new { icon="💧", text="Uống đủ 2 lít nước mỗi ngày để duy trì sức khỏe tốt." },
                                new { icon="🏃", text="Vận động ít nhất 30 phút mỗi ngày giúp tăng cường miễn dịch." },
                                new { icon="😴", text="Ngủ đủ 7-8 tiếng mỗi đêm để cơ thể phục hồi." },
                                new { icon="🥗", text="Ăn đủ rau xanh và trái cây để bổ sung vitamin." },
                                new { icon="🧘", text="Giữ tinh thần thoải mái, tránh stress kéo dài." }
                                };
                        var tip = tips[DateTime.Now.DayOfYear % tips.Length];
                    }
                    <div class="text-center mb-2" style="font-size:32px;">@tip.icon</div>
                    <p class="text-center mb-2" style="font-size:13px;color:#0369a1;line-height:1.6;">@tip.text</p>
                    <p class="text-center mb-0" style="font-size:11px;color:#aaa;">Lời khuyên thay đổi mỗi ngày</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        (async function () {
            const elLoading = document.getElementById('appt-loading');
            const elFound   = document.getElementById('appt-found');
            const elEmpty   = document.getElementById('appt-empty');

            try {
                const res  = await fetch('/api/appointments/upcoming');
                if (!res.ok) throw new Error('Unauthorized');
                const data = await res.json();

                elLoading.style.display = 'none';

                if (data && data.appointmentId) {
                    document.getElementById('appt-date').textContent =
                        '📅 ' + new Date(data.date).toLocaleString('vi-VN', {
                            weekday: 'long', day: '2-digit', month: '2-digit',
                            year: 'numeric', hour: '2-digit', minute: '2-digit'
                        });
                    document.getElementById('appt-doctor').innerHTML =
                        '<i class="bi bi-person-badge me-1"></i>' +
                        data.doctorName + ' &bull; ' + data.specialty;

                    const statusMap = {
                        'Pending'    : ['warning', '⏳ Chờ xác nhận'],
                        'Confirmed'  : ['success', '✅ Đã xác nhận'],
                        'InProgress' : ['primary', '🔄 Đang khám'],
                    };
                    const [color, label] = statusMap[data.status] ?? ['secondary', data.status];
                    document.getElementById('appt-status').innerHTML =
                        `<span class="badge bg-${color}-subtle text-${color}
                                border border-${color}-subtle"
                               style="font-size:11px;">${label}</span>`;

                    document.getElementById('appt-track-link').href =
                        '/Appointments/TrackProgress/' + data.appointmentId;

                    elFound.style.display = 'block';
                } else {
                    elEmpty.style.display = 'block';
                }
            } catch (e) {
                elLoading.style.display = 'none';
                elEmpty.style.display   = 'block';
            }
        })();
    </script>
}
else
{
    <style>
        .carousel-item img {
            height: 450px;
            object-fit: cover;
            width: 100%;
        }

        .transition-up {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .transition-up:hover {
                transform: translateY(-10px);
                box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
            }
    </style>

    @* ===== CAROUSEL - KHÔNG CÓ CAPTION ===== *@
    <div id="clinicCarousel" class="carousel slide carousel-fade mb-5 shadow-sm"
         data-bs-ride="carousel" style="border-radius:20px;overflow:hidden;">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#clinicCarousel" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#clinicCarousel" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#clinicCarousel" data-bs-slide-to="2"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active" data-bs-interval="5000">
                <img src="~/images/banners/banner1.jpg" alt="Banner 1">
            </div>
            <div class="carousel-item" data-bs-interval="5000">
                <img src="~/images/banners/banner2.jpg" alt="Banner 2">
            </div>
            <div class="carousel-item" data-bs-interval="5000">
                <img src="~/images/banners/banner3.jpg" alt="Banner 3">
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#clinicCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#clinicCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    @* ===== GIỚI THIỆU ===== *@
    <div class="container text-center py-4">
        <h2 class="fw-bold text-primary mb-3">Chào mừng tới Delta System</h2>
        <p class="text-muted mx-auto mb-5" style="max-width:700px;">
            Chúng tôi tự hào là đơn vị tiên phong trong chuyển đổi số y tế, mang đến trải nghiệm
            khám chữa bệnh nhanh chóng, bảo mật và hiệu quả cho mọi khách hàng.
        </p>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm text-center p-4 h-100 transition-up" style="border-radius:16px;">
                    <div class="icon-box mx-auto mb-3 bg-primary bg-opacity-10 rounded-circle
                                    d-flex align-items-center justify-content-center"
                         style="width:70px;height:70px;">
                        <i class="bi bi-people-fill text-primary" style="font-size:30px;"></i>
                    </div>
                    <h5>Đội ngũ Bác sĩ</h5>
                    <p class="text-muted small">Các chuyên gia Delta hàng đầu với nhiều năm kinh nghiệm từ các bệnh viện lớn.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-primary text-white text-center p-4 h-100 transition-up shadow"
                     style="border-radius:16px;">
                    <div class="icon-box mx-auto mb-3 bg-white bg-opacity-20 rounded-circle
                                    d-flex align-items-center justify-content-center"
                         style="width:70px;height:70px;">
                        <i class="bi bi-calendar-check-fill text-white" style="font-size:30px;"></i>
                    </div>
                    <h5>Đặt lịch 24/7</h5>
                    <p class="small" style="opacity:.85;">Dễ dàng chọn bác sĩ và thời gian khám qua website bất cứ lúc nào.</p>
                    <a asp-controller="Account" asp-action="Login"
                       class="btn btn-light btn-sm fw-bold text-primary mt-2">ĐĂNG NHẬP NGAY</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm text-center p-4 h-100 transition-up" style="border-radius:16px;">
                    <div class="icon-box mx-auto mb-3 bg-primary bg-opacity-10 rounded-circle
                                    d-flex align-items-center justify-content-center"
                         style="width:70px;height:70px;">
                        <i class="bi bi-shield-lock-fill text-primary" style="font-size:30px;"></i>
                    </div>
                    <h5>Bảo mật hồ sơ</h5>
                    <p class="text-muted small">Thông tin y tế và lịch sử khám của bạn được Delta bảo vệ an toàn tuyệt đối.</p>
                </div>
            </div>
        </div>
    </div>
}
