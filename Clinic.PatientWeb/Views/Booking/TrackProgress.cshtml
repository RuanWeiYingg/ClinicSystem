@model Clinic.Shared.Model.Appointment
@{
    ViewData["Title"] = "Tiến độ thăm khám";

    var (progressPct, progressStep) = Model.Status switch
    {
        "Pending" => (25, 1),
        "Confirmed" => (50, 2),
        "InProgress" => (75, 3),
        "Completed" => (100, 4),
        _ => (0, 0)
    };

    string StepIcon(int step) => step < progressStep ? "bg-success bi-check"
                               : step == progressStep ? "bg-primary bi-hourglass-split"
                               : "bg-light bi-circle";
}

<div class="container mt-4">
    <div class="row g-4">

        @* --- CỘT TRÁI --- *@
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 mb-4" style="border-radius:15px;">
                <div class="card-header bg-white py-3 border-0">
                    <div class="d-flex align-items-center justify-content-between">
                        <h5 class="mb-0 fw-bold text-primary">
                            <i class="bi bi-activity me-2"></i>TIẾN ĐỘ THĂM KHÁM
                        </h5>
                        @{
                            var (badgeColor, badgeLabel) = Model.Status switch
                            {
                                "Pending" => ("warning", "⏳ Chờ xác nhận"),
                                "Confirmed" => ("success", "✅ Đã xác nhận"),
                                "InProgress" => ("primary", "🔄 Đang khám"),
                                "Completed" => ("success", "🏁 Hoàn thành"),
                                _ => ("secondary", Model.Status)
                            };
                        }
                        <span class="badge bg-@(badgeColor)-subtle text-@badgeColor
                                     border border-@(badgeColor)-subtle"
                              style="font-size:12px;">@badgeLabel</span>
                    </div>
                </div>
                <div class="card-body p-4">

                    @* Progress Bar động *@
                    <div class="position-relative mb-5 mt-3">
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-success"
                                 style="width:@progressPct%; transition:width 0.8s ease;"></div>
                        </div>
                        <div class="d-flex justify-content-between position-absolute
                                    top-50 start-0 translate-middle-y w-100">
                            @for (int i = 1; i <= 4; i++)
                            {
                                var icon = StepIcon(i);
                                var parts = icon.Split(' ');
                                var bgCls = parts[0];
                                var iCls = parts[1];
                                var size = i == progressStep ? "35px" : "30px";
                                var bdr = i == progressStep ? "border:4px solid white;" : "";
                                <div class="@bgCls text-white rounded-circle d-flex
                                            align-items-center justify-content-center shadow"
                                     style="width:@size;height:@size;@bdr">
                                    <i class="bi @iCls" style="font-size:13px;"></i>
                                </div>
                            }
                        </div>
                    </div>

                    @* Chi tiết các bước *@
                    <div class="mt-4">
                        @{
                            var steps = new[] {
                        new { label = "Tiếp nhận hồ sơ",
                        sub   = "Quầy lễ tân" },
                        new { label = "Khám lâm sàng",
                        sub   = $"BS. {Model.Doctor?.User?.FullName} - Phòng khám" },
                        new { label = "Chờ kết quả xét nghiệm",
                        sub   = "Phòng Lab" },
                        new { label = "Kết luận & Nhận đơn thuốc",
                        sub   = "Bước cuối cùng" }
                        };
                        }
                        @for (int i = 0; i < steps.Length; i++)
                        {
                            int stepNum = i + 1;
                            bool done = stepNum < progressStep;
                            bool current = stepNum == progressStep;
                            bool pending = stepNum > progressStep;

                            <div class="d-flex gap-3 mb-4
                                        @(current ? "pulse-status" : "")
                                        @(pending  ? "opacity-50"   : "")">
                                <div class="fs-4">
                                    @if (done)
                                    {
                                        <i class="bi bi-check-circle-fill text-success"></i>
                                    }
                                    else if (current)
                                    {
                                        <i class="bi bi-arrow-right-circle-fill text-primary"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-circle text-secondary"></i>
                                    }
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold @(current ? "text-primary" : "")">
                                        @steps[i].label
                                    </h6>
                                    <small class="text-muted">@steps[i].sub</small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* --- CỘT PHẢI --- *@
        <div class="col-lg-5">

            @* Thông tin lịch hẹn *@
            <div class="card shadow-sm border-0 mb-4"
                 style="border-radius:15px; background:#f0f9ff;">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-dark mb-3">
                        <i class="bi bi-calendar2-check me-2 text-primary"></i>THÔNG TIN LỊCH HẸN
                    </h6>
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-muted">Bệnh nhân</span>
                        <span class="fw-bold">@Model.Patient?.FullName</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-muted">Bác sĩ</span>
                        <span class="fw-bold">BS. @Model.Doctor?.User?.FullName</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-muted">Dịch vụ</span>
                        <span class="fw-bold">@Model.Service?.ServiceName</span>
                    </div>
                    <div class="d-flex justify-content-between small">
                        <span class="text-muted">Ngày khám</span>
                        <span class="fw-bold">
                            @Model.AppointmentDate.ToString("HH:mm - dd/MM/yyyy")
                        </span>
                    </div>
                </div>
            </div>

            @* Chi phí *@
            <div class="card shadow-sm border-0 mb-4"
                 style="border-radius:15px; background:#fffdf5;">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-dark mb-3">CHI PHÍ TẠM TÍNH</h6>
                    <div class="d-flex justify-content-between mb-2 small">
                        <span>@Model.Service?.ServiceName</span>
                        <span class="fw-bold">@Model.Service?.Price.ToString("N0")đ</span>
                    </div>

                    @* ✅ SỬA: Invoices (số nhiều) *@
                    @if (Model.Invoices != null && Model.Invoices.Any())
                    {
                        var inv = Model.Invoices.First();
                        <div class="d-flex justify-content-between mb-2 small">
                            <span class="text-muted">Trạng thái thanh toán</span>
                            <span class="badge bg-@(inv.Status == "Paid" ? "success" : "warning")-subtle
                                         text-@(inv.Status == "Paid" ? "success" : "warning")">
                                @(inv.Status == "Paid" ? "✅ Đã thanh toán" : "⏳ Chưa thanh toán")
                            </span>
                        </div>
                    }
                    <hr>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-primary">TỔNG CỘNG</span>
                        <h4 class="fw-bold text-primary mb-0">
                            @Model.Service?.Price.ToString("N0")đ
                        </h4>
                    </div>
                </div>
            </div>

            @* Đơn thuốc *@
            <div class="card shadow-sm border-0" style="border-radius:15px;">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-dark mb-3">
                        <i class="bi bi-capsule-pill me-2"></i>ĐƠN THUỐC (NẾU CÓ)
                    </h6>

                    @* ✅ SỬA: MedicalRecords (số nhiều) cả 2 chỗ *@
                    @if (Model.MedicalRecords != null && Model.MedicalRecords.Any())
                    {
                        @foreach (var record in Model.MedicalRecords)
                        {
                            <div class="p-3 bg-light rounded-3 mb-3
                                        border-start border-success border-4">
                                <p class="mb-1 fw-bold text-success" style="font-size:13px;">
                                    <i class="bi bi-clipboard2-pulse me-1"></i>Chẩn đoán
                                </p>
                                <small class="text-muted">@record.Diagnosis</small>
                            </div>

                            @if (!string.IsNullOrEmpty(record.TreatmentPlan))
                            {
                                <div class="p-3 bg-light rounded-3 mb-3
                                            border-start border-warning border-4">
                                    <p class="mb-1 fw-bold text-warning" style="font-size:13px;">
                                        <i class="bi bi-journal-medical me-1"></i>Phác đồ điều trị
                                    </p>
                                    <small class="text-muted">@record.TreatmentPlan</small>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(record.Prescription))
                            {
                                <div class="p-3 bg-light rounded-3 mb-3
                                            border-start border-primary border-4">
                                    <p class="mb-1 fw-bold" style="font-size:13px;">
                                        <i class="bi bi-capsule me-1 text-primary"></i>Đơn thuốc
                                    </p>
                                    <small class="text-muted" style="white-space:pre-line;">
                                        @record.Prescription
                                    </small>
                                </div>
                                <button class="btn btn-outline-primary w-100 mt-2 shadow-sm">
                                    <i class="bi bi-download me-2"></i>Tải đơn thuốc PDF
                                </button>
                            }
                        }
                    }
                    else
                    {
                        <div class="text-center py-3 text-muted">
                            <i class="bi bi-capsule" style="font-size:32px;opacity:.3;"></i>
                            <p class="mt-2 mb-0" style="font-size:13px;">
                                @(Model.Status == "Completed"
                                    ? "Không có đơn thuốc"
                                    : "Chưa có kết quả khám")
                            </p>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .pulse-status {
        animation: pulse-blue 2s infinite;
        padding: 5px;
        border-radius: 8px;
    }

    @@keyframes pulse-blue {
        0% {
            background-color: rgba(13,110,253,0);
        }

        50% {
            background-color: rgba(13,110,253,0.05);
        }

        100% {
            background-color: rgba(13,110,253,0);
        }
    }
</style>